# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-string

# Set to 'production' on your server — enables secure cookies and hides error details
NODE_ENV=development

FRONTEND_URL=http://localhost:5173
PORT=3001

# Local: postgresql://localhost/timesheet_db
# Production (Railway/Render/Supabase): postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://localhost/timesheet_db

# Get DSN from sentry.io — leave empty to disable Sentry
SENTRY_DSN=

# SMTP settings for reminder emails (nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=timesheet@example.com

# Submission reminder cron job
# Set to 'false' to disable reminders entirely
REMINDER_ENABLED=true
# Cron expression — default: Friday at 17:00 server time
REMINDER_CRON=0 17 * * 5
