# ─────────────────────────────────────────────
# LOCAL DEVELOPMENT
# Run: caddy run --config Caddyfile
# Access: https://localhost (Caddy auto-generates a local TLS cert)
# ─────────────────────────────────────────────
localhost {
	# Serve the built frontend (run `npm run build` in frontend/ first)
	root * ./frontend/dist
	file_server

	# Proxy all API requests to the Express backend
	reverse_proxy /api/* localhost:3001

	# SPA fallback — send all unmatched routes to index.html
	try_files {path} /index.html

	# Compression
	encode gzip
}

# ─────────────────────────────────────────────
# PRODUCTION
# Replace `yourdomain.com` with your real domain.
# Caddy will auto-obtain and renew a Let's Encrypt TLS cert.
# Ensure DNS A record points to this server's IP before starting.
# ─────────────────────────────────────────────
